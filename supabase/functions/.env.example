# Required secrets for Edge Functions
# Copy to supabase/functions/.env for local dev (never commit .env)

# Resend API key for email sending (https://resend.com)
RESEND_API_KEY=

# Email recipients
PLATFORM_EMAIL=team@pflegeleicht.online
PARTNER_EMAIL=test_agentur@pflegeleicht.online

# OpenRouter API key for LLM calls (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
